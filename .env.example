# ── LLM ──────────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# ── Database (Neon Postgres for production, local Postgres for dev) ──────────
DATABASE_URL=postgresql://argus:argus@localhost:5432/argus
# For Neon: postgresql://user:pass@ep-xxx.neon.tech/argus?sslmode=require

# ── News ─────────────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=argus@yourdomain.com

# ── Google (local dev; in CI use GOOGLE_CREDENTIALS_JSON secret instead) ─────
# GOOGLE_CREDENTIALS_JSON={"type": "service_account", ...}

# ── Dashboard ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
